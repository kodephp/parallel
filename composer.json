{
    "name": "kode/parallel",
    "description": "适用于 PHP 8.1+ 的高性能并行并发扩展库，提供 Runtime、Task、Future、Channel、Events、Fiber、Sync、Pipe、CurlMulti 等完整功能，支持 PHP 8.5 新特性",
    "keywords": [
        "parallel",
        "concurrency",
        "async",
        "multithreading",
        "fiber",
        "coroutine",
        "kode",
        "高性能",
        "并行",
        "并发",
        "协程"
    ],
    "type": "library",
    "version": "1.2.0",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "KodePHP",
            "email": "contact@kodephp.com",
            "homepage": "https://github.com/kodephp"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-parallel": "*"
    },
    "suggest": {
        "kode/fibers": "增强的 Fiber 纤程支持，提供池化、超时、上下文传递等功能",
        "kode/context": "请求上下文传递支持",
        "kode/facade": "门面模式支持"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Parallel\\": "src/"
        },
        "files": [
            "src/functions.php",
            "src/Channel/functions.php",
            "src/Sync/functions.php",
            "src/Util/Php85.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Parallel\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
